  // decidability gate (Ledger::decide) + the generic `Thought` concept (the crossCorpus anchor a strategy's
  // grammar `require`s). Score / the rest of the Gate family follow the same rule. Tier-1 (JS providers).
  "name": "reason-kernel",
  "version": "0.1.0",
  "tier": 1,
  "description": "Shared reasoning-kernel foundation plugin: the Ledger primitive, the margin decidability gate, and the generic Thought concept.",
  "engine": "^1.3.0",
  "concepts": ["kernel"],
  "providerNamespaces": ["Ledger"],
  "entrypoints": { "providers": "./providers.js" },
  "deps": []
}
