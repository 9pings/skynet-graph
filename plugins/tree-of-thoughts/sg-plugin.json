{
  // tree-of-thoughts — beam search over a thought tree, the design's class-B shape: the STATE lives
  // in the graph as typed facts (nodes, depth, parent edges, snapped score bands, pruned flags —
  // inspectable, serializable, cascade-retractable), the SELECTION POLICY stays a thin imperative
  // driver (top-k beam per depth = an argmax over siblings, which the per-object expr-DSL cannot and
  // should not express — forcing it into rules is the named over-engineering trap). The PRUNE is
  // native: Live gates on `pruned == null` AND the parent's own Live flag (a recursive hop-watcher)
  // — pruning one node cascades its whole subtree out, zero code. Scoring uses the kernel's Score
  // brick (raw score → K1 band; the judge must be EXTERNAL — the generator scoring itself is the
  // refuted self-audit). Tier-1 (the driver factory).
  "name": "tree-of-thoughts",
  "version": "0.1.0",
  "tier": 1,
  "description": "Tree-of-Thoughts beam search: state-in-graph (depth/parent/band/pruned facts, native cascade prune via a recursive Live gate), thin deterministic beam driver, kernel Score banding. Built on reason-kernel.",
  "engine": "^1.3.0",
  "concepts": ["tot"],
  "providerNamespaces": [],
  "entrypoints": {
    "factories": { "createTreeOfThoughts": "./factory.js" }
  },
  "deps": [{ "name": "reason-kernel", "range": "^0.1.0" }]
}
