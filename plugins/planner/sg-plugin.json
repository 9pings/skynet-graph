{
  // planner (C7) — the plan-loop / graph-native context-projection capability: GRAMMAR (concepts/) +
  // ENGINE (lib/: context-project, serve-leaf, givens, dag-decompose, rebalance, forest, higher-order,
  // negotiate, forge-fallback, split-serve, segment-proxy, sound-invoke, slot-aware-serve, support,
  // leaf-io) + the createPlanLoop factory (factory.js). The CtxProj/AI/Support providers are factory-built
  // per run (they close over the injected serve/content fns), so there is no static providers.js — the
  // namespaces CtxProj and Support are reserved below.
  //
  // Sets `loop` + `loop-reactive` + `support` = the decompose-loop family (extension sets composed over
  // `loop` by deepmerge, the engine's conceptSets merge). The `AI` namespace is NOT claimed here: it is
  // ambient/shared in lib (makeDecomposeProviders AND reason-loop.js serve it, two alternative families).
  // lib/authoring keeps loop.js + typed-loop.js (shared with the learning family via parametric.js) —
  // they load the grammar from this plugin's files.
  "name": "planner",
  "version": "0.3.0",
  "tier": 1,
  "description": "C7 — plan-loop / graph-native context-projection: decompose → project bounded contexts → serve leaves → reassemble. Grammar + engine + factory.",
  "engine": "^1.3.0",
  "concepts": ["planner", "loop", "loop-reactive", "support"],
  "providerNamespaces": ["CtxProj", "Support"],
  "entrypoints": {
    "factories": { "createPlanLoop": "./factory.js" },
    // `plan` — the roadmap instance-type (R9): a named persistent plan with the C7 needs invariant
    // at the door; `sync` = plan_sync as an action (task-mirror reused verbatim). Zero grammar.
    "descriptor": "./descriptor.js"
  },
  "deps": []
}
