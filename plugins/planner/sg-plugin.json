{
  // planner (C7) — the plan-loop / graph-native context-projection grammar, extracted from
  // lib/authoring/context-project.js's inline CONCEPT_MAP (owner: no grammar hard-coded in code). This
  // tranche ships the GRAMMAR (Task/Step/Decompose) as files; the projection ENGINE (context-project.js +
  // its cluster serve-leaf/givens/dag-decompose/…) moves into this plugin in the next tranche. The CtxProj
  // providers are factory-built per run (they close over the injected `serve`), so there is no static
  // providers.js — createContextProjection supplies them; the namespace is reserved below.
  //
  // Sets `loop` + `loop-reactive` + `support` = the decompose-loop family, extracted from the inline
  // literals of lib/authoring/loop.js and support.js (same rule). `loop-reactive` and `support` are
  // EXTENSION sets composed over `loop` by deepmerge (the engine's conceptSets merge). The `AI` namespace
  // is NOT claimed here: it is ambient/shared in lib (makeDecomposeProviders AND reason-loop.js serve it,
  // two alternative families); `Support` is this plugin's own (makeSupportProviders, factory-built).
  "name": "planner",
  "version": "0.2.0",
  "tier": 1,
  "description": "C7 — plan-loop / context-projection grammar (Task/Step/Decompose) + the decompose-loop family (loop, loop-reactive, support). Grammar extracted; the engine follows.",
  "engine": "^1.3.0",
  "concepts": ["planner", "loop", "loop-reactive", "support"],
  "providerNamespaces": ["CtxProj", "Support"],
  "deps": []
}
