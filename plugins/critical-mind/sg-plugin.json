{
  // critical-mind (C9) — the external, auditable critical mind as a skynet-graph plugin. Two faces in one
  // bundle, SAME signature and result shape:
  //   • the GRAMMAR face (concepts/dialectic/ + factory-grammar.js, tranche 2 COMPLETE): the whole debate
  //     runs as a concept set on the native engine emergence — pool admission (Brainstorm/PoolReady/Split),
  //     witness leaves (Explore/Retry), ONE admission gate for declared AND generated theses (Established),
  //     append-only tally via reason-kernel's Ledger, G3 placement + the SINGLE generative pass as a
  //     null-guard (Uncertain/Generate), LIVE margin verdicts (a retraction re-decides natively),
  //     NormProbe/SettledNorm, Contested (dialectic, annotation-only). The `Dialectic` LLM providers
  //     (cite/brainstorm/split/propose/normProbe/attack) are FACTORY-BUILT per run (providers.js — they
  //     close over the host ask; the planner CtxProj precedent), hence no static provider entrypoint.
  //   • the imperative FACTORY (factory.js): the measured reference pipeline, kept exported one
  //     release as `createCriticalMindImperative`.
  // The GRAMMAR face is the DEFAULT `createCriticalMind` since the GPU parity re-measure (07-16:
  // live Q2, results + budgets + prompt sets byte-identical, replay bit-identical). Scripted parity
  // is permanently enforced by tests/unit/critique-grammar-parity.test.js.
  "name": "critical-mind",
  "version": "0.2.0",
  "tier": 1,
  "description": "C9 — external critical mind: witness gate, anchored 0-fabrication generation, append-only ledger, certification-aware margin verdict. Ships both the grammar face (the debate as a concept set) and the imperative reference.",
  "engine": "^1.3.0",
  "concepts": ["dialectic"],
  "providerNamespaces": ["Dialectic"],
  "entrypoints": {
    "factories": {
      "createCriticalMind": "./factory-grammar.js",
      "createCriticalMindImperative": "./factory.js",
      "buildCritiqueBrief": "./brief.js",
      "renderJudgePrompt": "./brief.js"
    }
  },
  "deps": [{ "name": "reason-kernel", "range": "^0.1.0" }]
}
