{
  // critical-mind (C9) — the external, auditable critical mind as a skynet-graph plugin. Two faces in one
  // bundle: the GRAMMAR ledger-core (concepts/dialectic/ — witness gate, append-only ledger, native cascade
  // retraction; its Pro/ConEntry tally into ledger.pro/con via reason-kernel's Ledger primitive) and the
  // imperative FACTORY (factory.js) that drives the measured full pipeline (establish → generate anchored theses
  // → typed ledger → certification-aware verdict at the decidability margin). The Dialectic namespace is
  // RESERVED for C9's own LLM providers (cite/propose/synthesize — added in a later tranche); the generic
  // ledger tally/untally moved DOWN to reason-kernel (deps below).
  "name": "critical-mind",
  "version": "0.1.0",
  "tier": 1,
  "description": "C9 — external critical mind: witness gate, anchored 0-fabrication generation, append-only ledger, certification-aware margin verdict.",
  "engine": "^1.3.0",
  "concepts": ["dialectic"],
  "providerNamespaces": ["Dialectic"],
  "entrypoints": {
    "factories": { "createCriticalMind": "./factory.js" }
  },
  "deps": [{ "name": "reason-kernel", "range": "^0.1.0" }]
}
