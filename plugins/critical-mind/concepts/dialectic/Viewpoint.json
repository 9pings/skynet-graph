{
  // A point of view to establish against the pool (declared by the caller or generated).
  // Pure-assert -> auto-flags `Viewpoint`; the children Explore/Established are tested under it
  // (directory tree = IS-A). `text` is prose-terminal; `side` is a typed enum — OPTIONAL at
  // declaration (a side-less viewpoint gets its side INFERRED from its first witness by the
  // cite leaf, the imperative behaviour), which is why `side` is not required here.
  "require": ["isViewpoint"]
}
