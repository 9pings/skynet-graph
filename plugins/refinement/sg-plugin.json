{
  // refinement (iterative refinement / reflexion) — the THIRD client of reason-kernel and, like
  // self-consistency, a TIER-0 plugin (pure grammar, zero JS). Each attempt is a kernel Thought carrying a
  // raw score; the kernel snaps it to a band (Scored / Score::band). Accept = the ThresholdGate on the
  // snapped band (`$scoreBand == 'high'`, never a raw float — K1-clean, unlike the old raw `>= 0.6` gate);
  // Refine = the bounded refine signal (below threshold AND round < maxRounds, the null-guard-round). The
  // host produces the refined answer + score each round; this plugin is the accept/keep-going control flow.
  // The `reflexion` set is the SECOND accept gate of the same family: binary critiqueVerdict (CORRECT /
  // not) instead of the band threshold — Correct / Revise, same bound. The verdict must come from an
  // EXTERNAL critique source (judge model / oracle / test): the drafting model judging itself is the
  // REFUTED self-audit; the plugin deliberately ships no self-scoring path.
  "name": "refinement",
  "version": "0.2.0",
  "tier": 0,
  "description": "Iterative refinement / reflexion: accept on a snapped score band (refinement) or an external binary critique verdict (reflexion), bounded round budget. Tier-0, built on reason-kernel.",
  "engine": "^1.3.0",
  "concepts": ["refinement", "reflexion"],
  "providerNamespaces": [],
  "deps": [{ "name": "reason-kernel", "range": "^0.1.0" }]
}
