{
  // A step is SOLVED iff the host wrote its `answer` AND the step had been released (`require
  // Ready` — the ORDER GUARD: an out-of-order answer is structurally refused, the ladder is
  // load-bearing, never decorative). Solving tallies the step id into the plan ledger (kernel
  // Ledger::tally, append-only): the emergent order IS the audit trail — and it is what re-arms
  // the NEXT step's Ready gate (the chain). Self-flags `Solved` (cast-marker).
  "require": ["Ready", "answer"],
  "provider": ["Ledger::tally", "solved"]
}
