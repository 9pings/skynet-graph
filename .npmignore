# npm tarball = ONLY what's needed to EXECUTE + the .md docs.
# The package.json "files" allowlist is the PRIMARY control (default-deny); this denylist is the
# belt-and-suspenders (keeps the heavy/dev dirs out even if "files" is ever widened). Verify with
# `npm pack --dry-run` before publishing — the tarball must NOT contain models/, artifact/, or tests/.

# Heavy / non-exec (the big ones — models/ is tens of GB of gguf, NEVER ship)
/models/
/artifact/
/experiments/
/examples/
/tests/
/scripts/
/src/
/samples
/assets
/coverage
/.nyc_output

# doc: ship only the top-level *.md (via "files"); drop the heavy subdirs/images
/docs/*/
/docs/**/*.png
/docs/**/*.pdf
/docs/**/*.gif

# dev / local
node_modules/
*.log
*.tgz
.env
.env.*
.tmp

# OS / editor cruft
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.idea
*.sublime-workspace
